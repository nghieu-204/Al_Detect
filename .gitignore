docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment this out if so.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different models/versions of Python,
#   Pipfile.lock might cause dependency resolution conflicts.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#pdm.lock

# virtualenv
#   It's strongly recommended to exclude virtual environments from git!
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyder-py3

# Rope project settings
.ropeproject

# mkdocs documentation
/site

